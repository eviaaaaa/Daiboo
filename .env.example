# LLM API 配置
DASHSCOPE_API_KEY=your-qwen-api-key
GEMINI_API_KEY=your-gemini-api-key

# 可选：使用 OpenAI 兼容接口作为主聊天模型。
# 若 OPENAI_API_KEY 留空，运行时会自动回退到 DASHSCOPE_API_KEY + ChatTongyi。
OPENAI_API_KEY=your-openai-compatible-api-key
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# hCaptcha / 视觉求解配置
LLM_PROVIDER=glm
GLM_API_KEY=your-glm-api-key
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4.6v

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_password

# 目标网站配置示例
QFNU_USERNAME=your_student_id
QFNU_PASSWORD=your_password

# LangSmith 追踪配置（可选）
LANGSMITH_WORKSPACE_ID=api_key
LANGCHAIN_PROJECT_NAME=project_name

# ========================
# 浏览器配置
# ========================
BROWSER_PATH=path
USER_DATA_DIR=path
DEBUGGING_PORT=9222

# ========================
# Web 服务配置（可选）
# ========================
HOST=127.0.0.1
PORT=8801
UPLOAD_DIR=temp_uploads

# ========================
# Skills 配置（v0.1.0+）
# ========================
# Skills 技能目录路径（默认 skills/）
# DAIBOO_SKILLS_DIR=skills/

# SQLite checkpoint 数据目录（默认 data/）
# DAIBOO_CHECKPOINT_DIR=data/

# ========================
# API 安全（v0.1.0+，可选）
# ========================
# 设置后启用 API Key 认证；不设置则认证关闭
# DAIBOO_API_KEY=your-secret-api-key

# 滑动窗口限流（默认 60 req / 60s；设 0 关闭限流）
# RATE_LIMIT=60
# RATE_LIMIT_WINDOW=60

# ========================
# 日志配置（v0.1.0+，可选）
# ========================
# 日志级别：debug / info / warning / error（默认 info）
# LOG_LEVEL=info

# 日志格式：pretty（开发用，带颜色）/ json（生产用，结构化）
# LOG_FORMAT=pretty

# 日志文件路径（不设置则输出到 stderr）
# LOG_FILE=/var/log/daiboo.log
